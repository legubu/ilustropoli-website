---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollToTop from '../components/ScrollToTop.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = 'Ilustropoli — Arte original, talleres y más.',
  image = '/og-default.jpg',
  canonicalURL = Astro.url.href,
  jsonLd,
} = Astro.props;

const siteTitle = title === 'Ilustropoli' ? title : `${title} — Ilustropoli`;
const siteUrl = Astro.site?.toString() ?? 'https://ilustropoli.com/';

// Site-wide structured data, present on every page
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Ilustropoli',
  url: siteUrl,
  description: 'Arte original, ilustración y talleres creativos. Hermosillo, Sonora.',
  inLanguage: 'es-MX',
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Ilustropoli',
  url: siteUrl,
  logo: new URL('/favicon.svg', siteUrl).toString(),
  email: 'hola@ilustropoli.com',
  sameAs: ['https://instagram.com/ilustropoli'],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Hermosillo',
    addressRegion: 'Sonora',
    addressCountry: 'MX',
  },
};

// Escape `<` so a literal `</script>` in any string can't break out of the tag
const toJsonLd = (obj: unknown) => JSON.stringify(obj).replace(/</g, '\\u003c');

const pageSchemas = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{siteTitle}</title>

    <!-- Structured data (JSON-LD) -->
    <script type="application/ld+json" set:html={toJsonLd(websiteSchema)} />
    <script type="application/ld+json" set:html={toJsonLd(organizationSchema)} />
    {pageSchemas.map(schema => (
      <script type="application/ld+json" set:html={toJsonLd(schema)} />
    ))}

    <!-- Prevent dark mode flash on load — only activate if user explicitly chose it -->
    <script is:inline>
      if (localStorage.getItem('theme') === 'dark') document.documentElement.classList.add('dark');
    </script>

    <!-- Lazy image fade-in styles -->
    <style>
      img.lazy-fade {
        opacity: 0;
        transition: opacity 0.5s ease;
      }
      img.lazy-fade.loaded {
        opacity: 1;
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <ScrollToTop />

    <!-- Lazy image fade-in script -->
    <script>
      function applyFade(img: HTMLImageElement) {
        img.classList.add('lazy-fade');
        if (img.complete && img.naturalWidth > 0) {
          img.classList.add('loaded');
        } else {
          img.addEventListener('load', () => img.classList.add('loaded'), { once: true });
          // Fallback: show after 2s regardless
          setTimeout(() => img.classList.add('loaded'), 2000);
        }
      }
      // Apply to all images except header/nav icons
      document.querySelectorAll<HTMLImageElement>('main img').forEach(applyFade);
    </script>
  </body>
</html>
