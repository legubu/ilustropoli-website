---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkshopCard from '../components/WorkshopCard.astro';
import { getCollection } from 'astro:content';

const workshops = await getCollection('workshops');

const sorted = workshops.sort((a, b) =>
  new Date(a.data.date).getTime() - new Date(b.data.date).getTime()
);
---

<BaseLayout
  title="Talleres"
  description="Talleres de pintura y técnicas artísticas. Grupos pequeños, atención personalizada."
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-10">
      <p class="text-xs uppercase tracking-widest text-stone-400 mb-2">Aprender juntos</p>
      <h1 class="font-serif text-3xl sm:text-4xl font-semibold text-stone-900">Talleres</h1>
      <p class="mt-3 text-stone-500 max-w-xl">
        Grupos reducidos, materiales incluidos y atención personalizada.
        Cada taller es una experiencia completa.
      </p>
    </header>

    {sorted.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {sorted.map(w => (
          <WorkshopCard
            title={w.data.title}
            date={w.data.date}
            duration={w.data.duration}
            price={w.data.price}
            capacity={w.data.capacity}
            slug={w.slug}
          />
        ))}
      </div>
    ) : (
      <p class="text-stone-400 text-center py-20">No hay talleres programados por el momento.</p>
    )}
  </div>
</BaseLayout>
