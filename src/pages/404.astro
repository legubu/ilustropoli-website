---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página no encontrada">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <p class="font-serif text-6xl text-stone-200 font-semibold">404</p>
    <h1 class="font-serif text-2xl font-medium text-stone-900 dark:text-stone-100 mt-4">Página no encontrada</h1>
    <p class="mt-3 text-stone-500">Esta obra no existe o fue movida.</p>
    <a href="/" class="inline-block mt-8 border border-stone-300 text-stone-700 px-5 py-2.5 text-sm hover:border-stone-500 transition-colors">
      Volver al inicio
    </a>
  </div>
</BaseLayout>
