---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Mensaje enviado"
  description="Tu mensaje fue recibido."
>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <!-- Icon -->
    <div class="inline-flex items-center justify-center w-16 h-16 border border-stone-200 dark:border-stone-700 mb-8">
      <svg class="w-7 h-7 text-stone-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
    </div>

    <h1 class="font-serif text-3xl sm:text-4xl font-semibold text-stone-900 dark:text-stone-100">
      ¡Mensaje recibido!
    </h1>

    <p class="mt-4 text-stone-500 dark:text-stone-400 leading-relaxed max-w-md mx-auto">
      Gracias por escribirme. Te responderé a la brevedad.
    </p>

    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a
        href="/gallery"
        class="inline-block border border-stone-300 dark:border-stone-700 text-stone-700 dark:text-stone-300 px-5 py-2.5 text-sm hover:border-stone-500 dark:hover:border-stone-500 transition-colors"
      >
        Ver galería
      </a>
      <a
        href="/"
        class="inline-block text-stone-400 px-5 py-2.5 text-sm hover:text-stone-700 dark:hover:text-stone-200 transition-colors"
      >
        Volver al inicio
      </a>
    </div>
  </div>
</BaseLayout>
