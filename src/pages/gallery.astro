---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import { getCollection } from 'astro:content';

const artworks = await getCollection('artworks');

// Sort: featured first, then alphabetically
const sorted = artworks.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return a.data.title.localeCompare(b.data.title);
});
---

<BaseLayout
  title="Galería"
  description="Galería de obra original — pinturas, ilustraciones y más."
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-10">
      <p class="text-xs uppercase tracking-widest text-stone-400 mb-2">Colección</p>
      <h1 class="font-serif text-3xl sm:text-4xl font-semibold text-stone-900">Galería</h1>
      <p class="mt-3 text-stone-500 max-w-xl">
        Obra original disponible para adquirir. Cada pieza es única.
      </p>
    </header>

    {sorted.length > 0 ? (
      <GalleryGrid artworks={sorted} />
    ) : (
      <p class="text-stone-400 text-center py-20">Próximamente nuevas obras.</p>
    )}
  </div>
</BaseLayout>
