---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contacto"
  description="Ponete en contacto — consultas sobre obra, talleres o encargos."
>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <p class="text-xs uppercase tracking-widest text-stone-400 mb-2">Escribime</p>
    <h1 class="font-serif text-3xl sm:text-4xl font-semibold text-stone-900 dark:text-stone-100">Contacto</h1>
    <p class="mt-3 text-stone-500 dark:text-stone-400">
      Para consultas sobre obra original, encargos o talleres.
    </p>

    <!-- Contact options -->
    <div class="mt-10 space-y-4 border-t border-stone-200 dark:border-stone-800 pt-8">
      <div>
        <p class="text-xs uppercase tracking-widest text-stone-400 mb-1">Email</p>
        <a href="mailto:hola@ilustropoli.com" class="text-stone-800 dark:text-stone-200 hover:text-stone-500 dark:hover:text-stone-400 transition-colors">
          hola@ilustropoli.com
        </a>
      </div>
      <div>
        <p class="text-xs uppercase tracking-widest text-stone-400 mb-1">Instagram</p>
        <a
          href="https://instagram.com/ilustropoli"
          target="_blank"
          rel="noopener noreferrer"
          class="text-stone-800 dark:text-stone-200 hover:text-stone-500 dark:hover:text-stone-400 transition-colors"
        >
          @ilustropoli
        </a>
      </div>
    </div>

    <!-- Simple form (Netlify Forms) -->
    <form
      name="contact"
      method="POST"
      action="/mensaje-enviado"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="mt-12 space-y-5"
    >
      <input type="hidden" name="form-name" value="contact" />
      <p class="hidden">
        <label>No completar: <input name="bot-field" /></label>
      </p>

      <div>
        <label for="name" class="block text-xs uppercase tracking-widest text-stone-500 mb-1.5">Nombre</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full border border-stone-200 dark:border-stone-700 bg-white dark:bg-stone-800 px-4 py-2.5 text-stone-800 dark:text-stone-200 text-sm focus:outline-none focus:border-stone-500 dark:focus:border-stone-400 transition-colors"
        />
      </div>

      <div>
        <label for="email" class="block text-xs uppercase tracking-widest text-stone-500 mb-1.5">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full border border-stone-200 dark:border-stone-700 bg-white dark:bg-stone-800 px-4 py-2.5 text-stone-800 dark:text-stone-200 text-sm focus:outline-none focus:border-stone-500 dark:focus:border-stone-400 transition-colors"
        />
      </div>

      <div>
        <label for="message" class="block text-xs uppercase tracking-widest text-stone-500 mb-1.5">Mensaje</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full border border-stone-200 dark:border-stone-700 bg-white dark:bg-stone-800 px-4 py-2.5 text-stone-800 dark:text-stone-200 text-sm focus:outline-none focus:border-stone-500 dark:focus:border-stone-400 transition-colors resize-none"
        ></textarea>
      </div>

      <button
        type="submit"
        class="inline-block bg-stone-900 text-stone-50 px-6 py-3 text-sm font-medium tracking-wide hover:bg-stone-700 transition-colors"
      >
        Enviar mensaje
      </button>
    </form>
  </div>
</BaseLayout>
