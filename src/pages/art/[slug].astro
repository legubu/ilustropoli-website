---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ImageGallery from '../../components/ImageGallery.astro';
import BuyButton from '../../components/BuyButton.astro';
import { getCollection, render } from 'astro:content';

const tagEntries = await getCollection('tags');
const tagMap = Object.fromEntries(tagEntries.map(t => [t.slug, t.data.title]));

export async function getStaticPaths() {
  const artworks = await getCollection('artworks');

  // Same sort as gallery so prev/next matches the carousel order
  const sorted = artworks.sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return a.data.title.localeCompare(b.data.title);
  });

  return sorted.map((artwork, index) => ({
    params: { slug: artwork.slug },
    props: {
      artwork,
      prev: index > 0 ? sorted[index - 1] : null,
      next: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }));
}

const { artwork, prev, next } = Astro.props;
const { Content } = await render(artwork);

const { title, price, images, palette, surface, stock, payment_link, for_sale, category, tags } = artwork.data;
const resolvedTags = (tags ?? []).map(slug => tagMap[slug] ?? slug);

const formattedPrice = price
  ? new Intl.NumberFormat('es-MX', {
      style: 'currency',
      currency: 'MXN',
      maximumFractionDigits: 0,
    }).format(price)
  : null;

const inStock = stock > 0;
const canBuy = for_sale && payment_link && inStock;

// Structured data — VisualArtwork with nested Offer when the piece is for sale
const artworkDescription = [surface, palette].filter(Boolean).join(' · ') || `${title} — Obra original.`;
const artworkSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'VisualArtwork',
  name: title,
  image: new URL(images[0], Astro.site).toString(),
  url: Astro.url.href,
  description: artworkDescription,
  creator: { '@type': 'Organization', name: 'Ilustropoli' },
};
if (category) artworkSchema.artMedium = category;
if (surface) artworkSchema.artworkSurface = surface;
if (for_sale && price != null) {
  artworkSchema.offers = {
    '@type': 'Offer',
    price,
    priceCurrency: 'MXN',
    availability: inStock ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
    url: Astro.url.href,
    itemCondition: 'https://schema.org/NewCondition',
  };
}
---

<BaseLayout
  title={title}
  description={`${title} — Obra original. ${surface ?? ''}`.trim()}
  image={images[0]}
  jsonLd={artworkSchema}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Back -->
    <a href="/gallery" class="inline-flex items-center gap-1 text-sm text-stone-400 hover:text-stone-700 dark:hover:text-stone-200 transition-colors mb-8">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      Galería
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
      <!-- Images -->
      <div>
        <ImageGallery images={images} title={title} />
      </div>

      <!-- Details -->
      <div class="lg:pt-4">
        <h1 class="font-serif text-3xl sm:text-4xl font-semibold text-stone-900 dark:text-stone-100 leading-tight">{title}</h1>

        {formattedPrice && for_sale && (
          <p class="mt-4 text-2xl font-serif text-stone-700 dark:text-stone-300">{formattedPrice}</p>
        )}

        <!-- Specs -->
        <dl class="mt-6 space-y-2 text-sm border-t border-stone-200 dark:border-stone-700 pt-6">
          {surface && (
            <div class="flex gap-3">
              <dt class="text-stone-400 w-24 flex-shrink-0">Soporte</dt>
              <dd class="text-stone-700 dark:text-stone-300">{surface}</dd>
            </div>
          )}
          {palette && (
            <div class="flex gap-3">
              <dt class="text-stone-400 w-24 flex-shrink-0">Paleta</dt>
              <dd class="text-stone-700 dark:text-stone-300">{palette}</dd>
            </div>
          )}
          {for_sale && (
            <div class="flex gap-3">
              <dt class="text-stone-400 w-24 flex-shrink-0">Disponible</dt>
              <dd class={inStock ? 'text-green-700' : 'text-stone-400'}>
                {inStock ? `${stock} ${stock === 1 ? 'pieza' : 'piezas'}` : 'Agotada'}
              </dd>
            </div>
          )}
          {resolvedTags.length > 0 && (
            <div class="flex gap-3 pt-2">
              <dt class="text-stone-400 w-24 flex-shrink-0 sr-only">Etiquetas</dt>
              <dd class="flex flex-wrap gap-1.5">
                {resolvedTags.map(tag => (
                  <span class="text-xs px-2 py-0.5 border border-stone-200 dark:border-stone-700 text-stone-400 dark:text-stone-500">
                    {tag}
                  </span>
                ))}
              </dd>
            </div>
          )}
        </dl>

        <!-- Description -->
        <div class="mt-8 art-prose prose-stone text-stone-600 dark:text-stone-400 leading-relaxed space-y-4">
          <Content />
        </div>

        <!-- CTA -->
        <div class="mt-8">
          {canBuy ? (
            <>
              <BuyButton paymentLink={payment_link!} price={price} />
              <p class="mt-4 text-xs text-stone-400">
                Al hacer clic serás redirigido a MercadoPago para completar la compra de forma segura.
              </p>
            </>
          ) : for_sale && !inStock ? (
            <p class="text-sm text-stone-400 italic">Esta obra ya no está disponible.</p>
          ) : null}
        </div>
      </div>
    </div>

    <!-- ── Prev / Next navigation ─────────────────────────────── -->
    <nav class="mt-16 pt-8 border-t border-stone-200 dark:border-stone-700 grid grid-cols-2 gap-4">
      <!-- Prev -->
      <div>
        {prev ? (
          <a href={`/art/${prev.slug}`} class="group flex flex-col gap-2">
            <span class="text-xs uppercase tracking-widest text-stone-400 flex items-center gap-1">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/>
              </svg>
              Anterior
            </span>
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 overflow-hidden bg-stone-100 flex-shrink-0">
                <img
                  src={prev.data.images[0]}
                  alt={prev.data.title}
                  class="w-full h-full object-cover"
                  onerror="this.src='/images/placeholder.svg'"
                />
              </div>
              <span class="font-serif text-sm text-stone-700 dark:text-stone-300 group-hover:text-stone-400 transition-colors leading-snug">
                {prev.data.title}
              </span>
            </div>
          </a>
        ) : <span />}
      </div>

      <!-- Next -->
      <div class="text-right">
        {next ? (
          <a href={`/art/${next.slug}`} class="group flex flex-col gap-2 items-end">
            <span class="text-xs uppercase tracking-widest text-stone-400 flex items-center gap-1">
              Siguiente
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/>
              </svg>
            </span>
            <div class="flex items-center gap-3 flex-row-reverse">
              <div class="w-12 h-12 overflow-hidden bg-stone-100 flex-shrink-0">
                <img
                  src={next.data.images[0]}
                  alt={next.data.title}
                  class="w-full h-full object-cover"
                  onerror="this.src='/images/placeholder.svg'"
                />
              </div>
              <span class="font-serif text-sm text-stone-700 dark:text-stone-300 group-hover:text-stone-400 transition-colors leading-snug">
                {next.data.title}
              </span>
            </div>
          </a>
        ) : <span />}
      </div>
    </nav>

  </div>
</BaseLayout>
