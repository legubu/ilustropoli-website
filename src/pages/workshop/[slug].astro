---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const workshops = await getCollection('workshops');
  return workshops.map(workshop => ({
    params: { slug: workshop.slug },
    props: { workshop },
  }));
}

const { workshop } = Astro.props;
const { Content } = await render(workshop);

const { title, date, duration, price, capacity, image } = workshop.data;

const formattedPrice = new Intl.NumberFormat('es-MX', {
  style: 'currency',
  currency: 'MXN',
  maximumFractionDigits: 0,
}).format(price);

const formattedDate = new Date(date + 'T12:00:00').toLocaleDateString('es-MX', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

// Structured data — Event with nested Offer, Place, and organizer
const workshopSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: title,
  startDate: date,
  description: `Taller: ${title}. ${duration}. ${formattedPrice}.`,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  location: {
    '@type': 'Place',
    name: 'Ilustropoli',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Hermosillo',
      addressRegion: 'Sonora',
      addressCountry: 'MX',
    },
  },
  organizer: {
    '@type': 'Organization',
    name: 'Ilustropoli',
    url: Astro.site?.toString(),
  },
  offers: {
    '@type': 'Offer',
    price,
    priceCurrency: 'MXN',
    availability: capacity > 0 ? 'https://schema.org/InStock' : 'https://schema.org/SoldOut',
    url: Astro.url.href,
  },
};
if (image) workshopSchema.image = new URL(image, Astro.site).toString();
---

<BaseLayout
  title={title}
  description={`Taller: ${title}. ${formattedDate}. ${duration}. ${formattedPrice}.`}
  jsonLd={workshopSchema}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Back -->
    <a href="/workshops" class="inline-flex items-center gap-1 text-sm text-stone-400 hover:text-stone-700 dark:hover:text-stone-200 transition-colors mb-8">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      Volver a talleres
    </a>

    {image && (
      <div class="mb-8 overflow-hidden aspect-[16/7] bg-stone-100 dark:bg-stone-800">
        <img
          src={image}
          alt={title}
          loading="eager"
          decoding="async"
          class="w-full h-full object-cover"
          onerror="this.src='/images/placeholder.svg'"
        />
      </div>
    )}

    <p class="text-xs uppercase tracking-widest text-stone-400 mb-3">Taller</p>
    <h1 class="font-serif text-3xl sm:text-4xl font-semibold text-stone-900 dark:text-stone-100 leading-tight">{title}</h1>

    <!-- Meta -->
    <dl class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-4 border-t border-b border-stone-200 dark:border-stone-700 py-6">
      <div>
        <dt class="text-xs uppercase tracking-widest text-stone-400 mb-1">Fecha</dt>
        <dd class="text-sm text-stone-800 dark:text-stone-200 capitalize">{formattedDate}</dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-widest text-stone-400 mb-1">Duración</dt>
        <dd class="text-sm text-stone-800 dark:text-stone-200">{duration}</dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-widest text-stone-400 mb-1">Cupos</dt>
        <dd class="text-sm text-stone-800 dark:text-stone-200">{capacity} personas</dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-widest text-stone-400 mb-1">Precio</dt>
        <dd class="text-sm text-stone-800 dark:text-stone-200 font-medium">{formattedPrice}</dd>
      </div>
    </dl>

    <!-- Content -->
    <div class="mt-8 art-prose prose-stone text-stone-600 dark:text-stone-400 leading-relaxed space-y-4 max-w-2xl">
      <Content />
    </div>

    <!-- CTA — reservation form -->
    <div class="mt-10 border-t border-stone-200 dark:border-stone-700 pt-8">

      {capacity === 0 ? (
        <!-- Sold out -->
        <div class="text-center py-6 border border-stone-200 dark:border-stone-700">
          <p class="text-sm font-medium text-stone-500 dark:text-stone-400">Cupos agotados</p>
          <p class="text-xs text-stone-400 mt-1">Ya no hay lugares disponibles para este taller.</p>
        </div>

      ) : (
        <>
          <h2 class="font-serif text-xl font-medium text-stone-900 dark:text-stone-100 mb-1">
            Reservar lugar
          </h2>
          <p class="text-sm text-stone-500 dark:text-stone-400 mb-6">
            Llena el formulario y te enviamos el enlace de pago para confirmar tu lugar.
          </p>

          <form
            name="reserva-taller"
            method="POST"
            action="/reserva-enviada"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="space-y-4 max-w-lg"
          >
            <input type="hidden" name="form-name" value="reserva-taller" />
            <input type="hidden" name="taller" value={title} />
            <p class="hidden"><label>No completar: <input name="bot-field" /></label></p>

            <div>
              <label for="res-nombre" class="block text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-1.5">
                Nombre *
              </label>
              <input
                type="text"
                id="res-nombre"
                name="nombre"
                required
                class="w-full border border-stone-200 dark:border-stone-700 bg-white dark:bg-stone-800 px-4 py-2.5 text-stone-800 dark:text-stone-200 text-sm focus:outline-none focus:border-stone-500 dark:focus:border-stone-400 transition-colors"
              />
            </div>

            <div>
              <label for="res-email" class="block text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-1.5">
                Email *
              </label>
              <input
                type="email"
                id="res-email"
                name="email"
                required
                class="w-full border border-stone-200 dark:border-stone-700 bg-white dark:bg-stone-800 px-4 py-2.5 text-stone-800 dark:text-stone-200 text-sm focus:outline-none focus:border-stone-500 dark:focus:border-stone-400 transition-colors"
              />
            </div>

            <div>
              <label for="res-telefono" class="block text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-1.5">
                Teléfono <span class="normal-case text-stone-400">(opcional)</span>
              </label>
              <input
                type="tel"
                id="res-telefono"
                name="telefono"
                class="w-full border border-stone-200 dark:border-stone-700 bg-white dark:bg-stone-800 px-4 py-2.5 text-stone-800 dark:text-stone-200 text-sm focus:outline-none focus:border-stone-500 dark:focus:border-stone-400 transition-colors"
              />
            </div>

            <div>
              <label for="res-comentario" class="block text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-1.5">
                Comentario <span class="normal-case text-stone-400">(opcional)</span>
              </label>
              <textarea
                id="res-comentario"
                name="comentario"
                rows="3"
                class="w-full border border-stone-200 dark:border-stone-700 bg-white dark:bg-stone-800 px-4 py-2.5 text-stone-800 dark:text-stone-200 text-sm focus:outline-none focus:border-stone-500 dark:focus:border-stone-400 transition-colors resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="inline-block bg-stone-900 dark:bg-stone-100 text-stone-50 dark:text-stone-900 px-6 py-3 text-sm font-medium tracking-wide hover:bg-stone-700 dark:hover:bg-stone-300 transition-colors"
            >
              Reservar mi lugar
            </button>
          </form>

          <p class="mt-4 text-xs text-stone-400">
            Una vez revisada tu solicitud, te enviaremos el enlace de pago por email.
            El lugar queda confirmado al completar el pago.
          </p>
        </>
      )}
    </div>
  </div>
</BaseLayout>
