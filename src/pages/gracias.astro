---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="¡Gracias por tu compra!"
  description="Tu compra fue procesada exitosamente."
>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <!-- Icon -->
    <div class="inline-flex items-center justify-center w-16 h-16 border border-stone-200 mb-8">
      <svg class="w-7 h-7 text-stone-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"/>
      </svg>
    </div>

    <h1 class="font-serif text-3xl sm:text-4xl font-semibold text-stone-900 dark:text-stone-100">¡Gracias!</h1>

    <div id="status-message">
      <p class="mt-4 text-stone-500 leading-relaxed">
        Tu pago fue procesado correctamente.<br />
        Te contactaré pronto para coordinar los detalles.
      </p>
    </div>

    <!-- Payment status from MercadoPago URL params -->
    <div id="payment-info" class="hidden mt-6 text-sm text-stone-400 border border-stone-100 p-4"></div>

    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a
        href="/gallery"
        class="inline-block border border-stone-300 text-stone-700 px-5 py-2.5 text-sm hover:border-stone-500 transition-colors"
      >
        Ver más obras
      </a>
      <a
        href="/"
        class="inline-block text-stone-400 px-5 py-2.5 text-sm hover:text-stone-700 dark:hover:text-stone-200 transition-colors"
      >
        Volver al inicio
      </a>
    </div>
  </div>
</BaseLayout>

<script>
  // MercadoPago sends these params on redirect:
  // ?collection_status=approved&payment_id=XXX&status=approved
  const params = new URLSearchParams(window.location.search);
  const status = params.get('collection_status') || params.get('status');
  const paymentId = params.get('payment_id') || params.get('collection_id');

  const statusMessage = document.getElementById('status-message');
  const paymentInfo = document.getElementById('payment-info');

  if (status === 'approved') {
    if (statusMessage) {
      statusMessage.innerHTML = `
        <p class="mt-4 text-stone-500 leading-relaxed">
          Tu pago fue aprobado correctamente.<br />
          Me pondré en contacto contigo a la brevedad para coordinar la entrega.
        </p>
      `;
    }
  } else if (status === 'pending' || status === 'in_process') {
    if (statusMessage) {
      statusMessage.innerHTML = `
        <p class="mt-4 text-stone-500 leading-relaxed">
          Tu pago está siendo procesado.<br />
          Te notificaremos cuando se confirme.
        </p>
      `;
    }
  } else if (status === 'rejected') {
    if (statusMessage) {
      statusMessage.innerHTML = `
        <p class="mt-4 text-red-400 leading-relaxed">
          El pago no pudo procesarse.<br />
          Por favor intenta nuevamente o contáctame directamente.
        </p>
      `;
    }
  }

  if (paymentId && paymentInfo) {
    paymentInfo.classList.remove('hidden');
    paymentInfo.textContent = `Referencia de pago: ${paymentId}`;
  }
</script>
