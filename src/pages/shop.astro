---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArtworkCard from '../components/ArtworkCard.astro';
import CategoryFilter from '../components/CategoryFilter.astro';
import { getCollection } from 'astro:content';

const artworks = await getCollection('artworks');
const forSale = artworks
  .filter(a => a.data.for_sale)
  .sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return a.data.title.localeCompare(b.data.title);
  });

const categories = ['acuarela', 'acrilico', 'sketch'] as const;
const counts = Object.fromEntries(
  categories.map(cat => [cat, forSale.filter(a => a.data.category === cat).length])
);
const usedCategories = categories.filter(c => counts[c] > 0);
---

<BaseLayout
  title="Tienda"
  description="Obra original disponible para adquirir. Cada pieza es única."
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-8">
      <p class="text-xs uppercase tracking-widest text-stone-400 mb-2">Obra disponible</p>
      <h1 class="font-serif text-3xl sm:text-4xl font-semibold text-stone-900">Tienda</h1>
      <p class="mt-3 text-stone-500 max-w-xl">
        Piezas originales disponibles para adquirir. Cada obra es única e irrepetible.
      </p>
    </header>

    {forSale.length > 0 ? (
      <>
        {usedCategories.length > 0 && (
          <CategoryFilter categories={usedCategories} counts={counts} total={forSale.length} />
        )}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-10">
          {forSale.map(artwork => (
            <div data-category-item={artwork.data.category ?? ''}>
              <ArtworkCard
                title={artwork.data.title}
                price={artwork.data.price!}
                image={artwork.data.images[0]}
                slug={artwork.slug}
                surface={artwork.data.surface}
              />
            </div>
          ))}
        </div>
      </>
    ) : (
      <div class="text-center py-20">
        <p class="text-stone-400">No hay obras disponibles para venta en este momento.</p>
        <a href="/gallery" class="inline-block mt-4 text-sm text-stone-500 underline underline-offset-2 hover:text-stone-800 transition-colors">
          Ver galería completa
        </a>
      </div>
    )}
  </div>
</BaseLayout>
