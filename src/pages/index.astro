---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import WorkshopCard from '../components/WorkshopCard.astro';
import { getCollection } from 'astro:content';

const allArtworks = await getCollection('artworks');
const allWorkshops = await getCollection('workshops');

const featured = allArtworks
  .filter(a => a.data.featured)
  .sort(() => 0); // preserve frontmatter order

const upcomingWorkshops = allWorkshops
  .filter(w => w.data.featured)
  .slice(0, 2);
---

<BaseLayout
  title="Ilustropoli"
  description="Arte original, ilustración y talleres creativos. Buenos Aires."
>
  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-20">
    <div class="max-w-2xl">
      <p class="text-xs uppercase tracking-widest text-stone-400 mb-4">Arte original · Buenos Aires</p>
      <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-semibold text-stone-900 leading-tight">
        Ilustropoli
      </h1>
      <p class="mt-6 text-lg text-stone-500 leading-relaxed">
        Obra original, ilustración y talleres de pintura.<br />
        Cada pieza lleva tiempo, intención y materia.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/gallery"
          class="inline-block bg-stone-900 text-stone-50 px-6 py-3 text-sm font-medium tracking-wide hover:bg-stone-700 transition-colors"
        >
          Ver galería
        </a>
        <a
          href="/workshops"
          class="inline-block border border-stone-300 text-stone-700 px-6 py-3 text-sm font-medium tracking-wide hover:border-stone-500 transition-colors"
        >
          Próximos talleres
        </a>
      </div>
    </div>
  </section>

  <!-- Featured artworks -->
  {featured.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="font-serif text-2xl font-medium text-stone-900">Obras destacadas</h2>
        <a href="/gallery" class="text-sm text-stone-400 hover:text-stone-700 transition-colors">Ver todo →</a>
      </div>
      <GalleryGrid artworks={featured} />
    </section>
  )}

  <!-- Workshops preview -->
  {upcomingWorkshops.length > 0 && (
    <section class="bg-stone-100 py-16">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-baseline justify-between mb-8">
          <h2 class="font-serif text-2xl font-medium text-stone-900">Próximos talleres</h2>
          <a href="/workshops" class="text-sm text-stone-400 hover:text-stone-700 transition-colors">Ver todos →</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {upcomingWorkshops.map(w => (
            <WorkshopCard
              title={w.data.title}
              date={w.data.date}
              duration={w.data.duration}
              price={w.data.price}
              capacity={w.data.capacity}
              slug={w.slug}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
