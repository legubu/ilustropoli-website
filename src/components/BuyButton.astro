---
interface Props {
  paymentLink: string;
  label?: string;
  price?: number;
}

const { paymentLink, label = 'Comprar esta obra', price } = Astro.props;

const formattedPrice = price
  ? new Intl.NumberFormat('es-AR', {
      style: 'currency',
      currency: 'ARS',
      maximumFractionDigits: 0,
    }).format(price)
  : null;
---

<a
  href={paymentLink}
  target="_blank"
  rel="noopener noreferrer"
  class="inline-flex items-center gap-2 bg-stone-900 text-stone-50 px-6 py-3 text-sm font-medium tracking-wide hover:bg-stone-700 transition-colors"
>
  {label}
  {formattedPrice && <span class="opacity-70">· {formattedPrice}</span>}
  <svg class="w-4 h-4 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
  </svg>
</a>
