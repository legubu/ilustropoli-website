---
interface Props {
  title: string;
  price: number;
  image: string;
  slug: string;
  surface?: string;
}

const { title, price, image, slug, surface } = Astro.props;

const formattedPrice = new Intl.NumberFormat('es-AR', {
  style: 'currency',
  currency: 'ARS',
  maximumFractionDigits: 0,
}).format(price);
---

<article class="group">
  <a href={`/art/${slug}`} class="block">
    <!-- Image container with consistent 3:4 aspect ratio -->
    <div class="aspect-[3/4] overflow-hidden bg-stone-100">
      <img
        src={image}
        alt={title}
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        onerror="this.src='/images/placeholder.svg'"
      />
    </div>

    <!-- Info -->
    <div class="mt-3">
      <h3 class="font-serif text-base font-medium text-stone-900 group-hover:text-stone-600 transition-colors">
        {title}
      </h3>
      {surface && (
        <p class="text-xs text-stone-400 mt-0.5">{surface}</p>
      )}
      <p class="text-sm font-medium text-stone-700 mt-1">{formattedPrice}</p>
    </div>
  </a>
</article>
