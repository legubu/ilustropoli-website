---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  price?: number;
  image: ImageMetadata;
  slug: string;
  surface?: string;
  tags?: string[];
}

const { title, price, image, slug, surface, tags = [] } = Astro.props;

const formattedPrice = price != null
  ? new Intl.NumberFormat('es-MX', {
      style: 'currency',
      currency: 'MXN',
      maximumFractionDigits: 0,
    }).format(price)
  : null;
---

<article class="group">
  <a href={`/art/${slug}`} class="block">
    <!-- Image container with consistent 3:4 aspect ratio -->
    <div class="aspect-[3/4] overflow-hidden bg-stone-100 dark:bg-stone-800">
      <Image
        src={image}
        alt={title}
        widths={[300, 500, 700]}
        sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    </div>

    <!-- Info -->
    <div class="mt-3">
      <h3 class="font-serif text-base font-medium text-stone-900 dark:text-stone-100 group-hover:text-stone-600 dark:group-hover:text-stone-400 transition-colors">
        {title}
      </h3>
      {surface && (
        <p class="text-xs text-stone-400 mt-0.5">{surface}</p>
      )}
      {formattedPrice && (
        <p class="text-sm font-medium text-stone-700 dark:text-stone-300 mt-1">{formattedPrice}</p>
      )}
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1 mt-2">
          {tags.map(tag => (
            <span class="text-[10px] px-2 py-0.5 border border-stone-200 dark:border-stone-700 text-stone-400 dark:text-stone-500 capitalize">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>
