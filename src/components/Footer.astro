---
const year = new Date().getFullYear();
---

<footer class="border-t border-stone-200 dark:border-stone-800 bg-stone-50 dark:bg-stone-950 mt-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex flex-col md:flex-row justify-between items-start gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="font-serif text-lg font-semibold text-stone-900 dark:text-stone-100">Ilustropoli</a>
        <p class="mt-1 text-sm text-stone-500 dark:text-stone-500">Arte original · Hermosillo, Sonora</p>
      </div>

      <!-- Links -->
      <nav class="flex flex-wrap gap-6 text-sm text-stone-500 dark:text-stone-500">
        <a href="/gallery" class="hover:text-stone-900 dark:hover:text-stone-200 transition-colors">Galería</a>
        <a href="/shop" class="hover:text-stone-900 dark:hover:text-stone-200 transition-colors">Tienda</a>
        <a href="/workshops" class="hover:text-stone-900 dark:hover:text-stone-200 transition-colors">Talleres</a>
        <a href="/about" class="hover:text-stone-900 dark:hover:text-stone-200 transition-colors">Sobre mí</a>
        <a href="/contact" class="hover:text-stone-900 dark:hover:text-stone-200 transition-colors">Contacto</a>
      </nav>
    </div>

    <p class="mt-8 text-xs text-stone-400 dark:text-stone-600 text-center md:text-left">
      &copy; {year} Ilustropoli. Todos los derechos reservados.
    </p>
  </div>
</footer>
