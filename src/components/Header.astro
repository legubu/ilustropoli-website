---
import DarkModeToggle from './DarkModeToggle.astro';

const navLinks = [
  { href: '/gallery', label: 'Galería' },
  { href: '/shop', label: 'Tienda' },
  { href: '/workshops', label: 'Talleres' },
  { href: '/about', label: 'Sobre mí' },
  { href: '/contact', label: 'Contacto' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-stone-200 dark:border-stone-800 bg-stone-50/90 dark:bg-stone-950/90 backdrop-blur-sm sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="font-serif text-xl font-semibold tracking-wide text-stone-900 dark:text-stone-100 hover:text-stone-600 dark:hover:text-stone-400 transition-colors">
        Ilustropoli
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`text-sm tracking-wide transition-colors ${
              currentPath.startsWith(link.href)
                ? 'text-stone-900 dark:text-stone-100 font-medium'
                : 'text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-100'
            }`}
          >
            {link.label}
          </a>
        ))}
        <DarkModeToggle />
      </nav>

      <!-- Mobile right side: dark toggle + hamburger -->
      <div class="flex items-center gap-1 md:hidden">
        <DarkModeToggle />
        <button
          id="nav-toggle"
          class="p-2 text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-100"
          aria-label="Abrir menú"
          aria-expanded="false"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile nav drawer -->
    <nav id="mobile-nav" class="hidden md:hidden pb-4 border-t border-stone-100 dark:border-stone-800 pt-3">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`block py-2 text-sm ${
            currentPath.startsWith(link.href)
              ? 'text-stone-900 dark:text-stone-100 font-medium'
              : 'text-stone-500 dark:text-stone-400'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
